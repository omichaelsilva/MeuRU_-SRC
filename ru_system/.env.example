# Chave secreta para JWT — gere uma chave aleatória forte em produção
# Exemplo: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua_chave_secreta_aqui_mude_em_producao

# Algoritmo JWT
ALGORITHM=HS256

# URL base da aplicação (usado nos links de email)
BASE_URL=http://localhost:8000

# Configurações de email (SMTP)
# Deixe EMAIL_HOST vazio para usar o modo dev (link impresso no terminal)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@ru.edu.br

# Para usar Gmail:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=seu@gmail.com
# EMAIL_PASS=sua_senha_de_app

# Para migrar para PostgreSQL, altere DATABASE_URL:
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/ru_db
# (e instale psycopg2-binary no requirements.txt)
DATABASE_URL=sqlite:///./ru.db

# ── WhatsApp / Twilio ─────────────────────────────────────────────────────────
# Crie uma conta em twilio.com e ative o sandbox do WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sandbox: +14155238886  |  Produção: seu número aprovado pela Meta
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Números dos admins que recebem alertas de pico (sem +55, separados por vírgula)
# Exemplo: ADMIN_WHATSAPP_NUMEROS=62999990000,62988880000
ADMIN_WHATSAPP_NUMEROS=

# ── Configurações de pico ──────────────────────────────────────────────────────
# Quantas entradas em X minutos configuram pico
LIMIAR_PICO=15
JANELA_PICO_MIN=10
# Intervalo mínimo entre alertas de pico (evita spam)
INTERVALO_ALERTA_PICO_MIN=15
